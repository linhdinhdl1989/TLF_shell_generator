# Copy this file to .env and fill in values before running docker compose.
# Never commit .env to version control.

# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=tlf_user
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=tlf_shell_db
POSTGRES_PORT=5432

# ── FastAPI ───────────────────────────────────────────────────────────────
API_PORT=8000

# Set to postgresql+asyncpg://... for Postgres, or leave blank for SQLite dev
DATABASE_URL=

# Print every SQL statement to stdout (useful for debugging)
DB_ECHO=false

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── AI provider (future per-shell AI loop) ────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
